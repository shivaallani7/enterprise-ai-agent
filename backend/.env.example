# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-key
AZURE_SEARCH_CODE_INDEX=code-index
AZURE_SEARCH_DOCS_INDEX=docs-index
# Embedding model for hybrid vector search (leave empty to use keyword-only search)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_SEARCH_VECTOR_DIMENSIONS=3072

# Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-key
COSMOS_DATABASE=agent-db

# Key Vault
KEY_VAULT_URL=https://your-kv.vault.azure.net/

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-token
JIRA_PROJECT_KEY=PROJ
JIRA_USER_EMAIL=you@example.com

# App
APP_ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
